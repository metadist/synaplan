# ==============================================================================
# FRONTEND (Vite dev server) ENVIRONMENT
# ==============================================================================
# Copy to .env (git-ignored) and adjust values as needed.
# These are read by vite.config.ts. In Docker they are passed through
# docker-compose.yml's `frontend` service (with sensible defaults), so you
# normally don't need a .env file at all for local development.
# ==============================================================================

# --- Dev server host check (anti DNS-rebinding) ---
# Vite 5+ rejects requests whose Host header isn't allow-listed.
#
# DEFAULT: EMPTY — the check is ignored and EVERY host is accepted, so the dev
# server answers to all requests out of the box behind any domain or reverse
# proxy (no "Blocked request. This host is not allowed" error for anyone).
#
# To RESTRICT (e.g. on a shared/exposed box), set a comma-separated allow-list
# of hostnames — then ONLY those hosts may connect:
#   ALLOWED_HOSTS=app.example.com,dev.example.com
# ("true" / "all" are explicit aliases for "allow every host".)
ALLOWED_HOSTS=

# Backend the dev server proxies /api and /shared to. Defaults to
# http://localhost:8000 (or http://backend inside Docker compose).
# BACKEND_URL=http://localhost:8000

# Base path the app is served under (defaults to /).
# VITE_BASE_PATH=/
