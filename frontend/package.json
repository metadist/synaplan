{
  "name": "vite-vue-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:types && vite build",
    "build:widget": "vite build --config vite.config.widget.ts",
    "check:types": "vue-tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts --project=chromium --grep-invert '@plugin|@oidc'",
    "test:e2e:whatsapp": "playwright test --config=tests/e2e/playwright.config.ts --project=chromium --grep @whatsapp",
    "test:e2e:plugin:castingdata": "playwright test --config=tests/e2e/playwright.config.ts --project=chromium --grep @plugin tests/e2e/tests/castingdata-plugin.spec.ts",
    "test:e2e:firefox": "playwright test --config=tests/e2e/playwright.config.ts --project=firefox --grep-invert '@plugin|@oidc'",
    "test:e2e:oidc": "AUTH_METHOD=oidc playwright test --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:oidc-button": "AUTH_METHOD=oidc playwright test --config=tests/e2e/playwright.config.ts --project=chromium --grep @oidc-button",
    "test:e2e:oidc-redirect": "AUTH_METHOD=oidc playwright test --config=tests/e2e/playwright.config.ts --project=chromium-oidc-redirect",
    "test:e2e:mobile": "playwright test --config=tests/e2e/playwright.config.ts --project=chromium-mobile",
    "test:e2e:visual": "playwright test --config=tests/e2e/playwright.config.ts --project=chromium-visual",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report tests/e2e/reports/html",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,css,scss,md}\"",
    "generate:schemas": "node scripts/generate-schemas.js"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@heroicons/vue": "^2.2.0",
    "@iconify/vue": "^5.0.0",
    "@intlify/core-base": "^11.1.12",
    "@types/three": "^0.184.0",
    "centrifuge": "^5.5.3",
    "chart.js": "^4.5.1",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.0",
    "mermaid": "^11.12.2",
    "morphdom": "^2.7.8",
    "pinia": "^3.0.3",
    "three": "^0.184.0",
    "vue": "^3.4.38",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.1.12",
    "vue-recaptcha-v3": "^2.0.1",
    "vue-router": "^5.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/dompurify": "3.2.0",
    "@types/katex": "0.16.8",
    "@types/node": "22.19.21",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/ui": "4.1.9",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.8.0",
    "@vue/test-utils": "2.4.11",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "happy-dom": "20.10.4",
    "openapi-zod-client": "1.18.3",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "terser": "5.48.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  }
}
