{
  "id": "synaform",
  "name": "synaform",
  "namespace": "Plugin\\Synaform",
  "version": "3.1.0",
  "displayName": "Synaform",
  "description": "Organise data collection workflows into Collections: define variables, upload Word templates, gather datasets, and export with AI-powered extraction.",
  "author": "Synaplan",
  "homepage": "https://github.com/metadist/synaplan-synaform",
  "license": "MIT",
  "minSynaplanVersion": "1.0.0",
  "capabilities": ["api", "frontend", "migrations"],
  "routes": [
    {"path": "/setup-check", "method": "GET", "description": "Check plugin setup status"},
    {"path": "/setup", "method": "POST", "description": "Initialize plugin with defaults"},
    {"path": "/config", "method": "GET", "description": "Get plugin configuration"},
    {"path": "/config", "method": "PUT", "description": "Update plugin configuration"},
    {"path": "/forms", "method": "GET", "description": "List form definitions"},
    {"path": "/forms", "method": "POST", "description": "Create form definition"},
    {"path": "/forms/{formId}", "method": "GET", "description": "Get form definition"},
    {"path": "/forms/{formId}", "method": "PUT", "description": "Update form definition"},
    {"path": "/forms/{formId}", "method": "DELETE", "description": "Delete form definition"},
    {"path": "/forms/import-parse", "method": "POST", "description": "Parse pasted text or DOCX into form fields using AI"},
    {"path": "/candidates", "method": "GET", "description": "List candidates"},
    {"path": "/candidates", "method": "POST", "description": "Create candidate"},
    {"path": "/candidates/{candidateId}", "method": "GET", "description": "Get candidate detail"},
    {"path": "/candidates/{candidateId}", "method": "PUT", "description": "Update candidate"},
    {"path": "/candidates/{candidateId}", "method": "DELETE", "description": "Delete candidate"},
    {"path": "/candidates/{candidateId}/upload-cv", "method": "POST", "description": "Upload CV PDF"},
    {"path": "/candidates/{candidateId}/upload-doc", "method": "POST", "description": "Upload additional document"},
    {"path": "/candidates/{candidateId}/urls", "method": "POST", "description": "Attach a web URL (e.g. LinkedIn) as an AI-readable source"},
    {"path": "/candidates/{candidateId}/urls/{urlIndex}", "method": "DELETE", "description": "Remove an attached URL source"},
    {"path": "/candidates/{candidateId}/urls/{urlIndex}/refresh", "method": "POST", "description": "Re-fetch an attached URL source"},
    {"path": "/candidates/{candidateId}/extract", "method": "POST", "description": "Run AI extraction on CV"},
    {"path": "/candidates/{candidateId}/variables", "method": "GET", "description": "Get resolved variables"},
    {"path": "/candidates/{candidateId}/variables", "method": "PUT", "description": "Override variables"},
    {"path": "/templates", "method": "GET", "description": "List DOCX templates"},
    {"path": "/templates", "method": "POST", "description": "Upload DOCX template"},
    {"path": "/templates/{templateId}", "method": "GET", "description": "Get template with placeholders"},
    {"path": "/templates/{templateId}", "method": "PATCH", "description": "Update template metadata (name, language)"},
    {"path": "/templates/{templateId}", "method": "DELETE", "description": "Delete template"},
    {"path": "/templates/{templateId}/placeholders", "method": "GET", "description": "List detected placeholders"},
    {"path": "/templates/{templateId}/variable-suggestions", "method": "GET", "description": "Turn placeholders into ready-to-apply form fields (deterministic)"},
    {"path": "/templates/{templateId}/preview-html", "method": "GET", "description": "Cached HTML preview skeleton used by the live-preview panel"},
    {"path": "/templates/{templateId}/download", "method": "GET", "description": "Download original template"},
    {"path": "/candidates/{candidateId}/generate/{templateId}", "method": "POST", "description": "Generate filled document"},
    {"path": "/candidates/{candidateId}/documents", "method": "GET", "description": "List generated documents"},
    {"path": "/candidates/{candidateId}/documents/{documentId}/download", "method": "GET", "description": "Download generated DOCX"},
    {"path": "/candidates/{candidateId}/documents/{documentId}/pdf", "method": "GET", "description": "Stream PDF rendering (requires libreoffice on backend)"},
    {"path": "/candidates/{candidateId}/documents/{documentId}", "method": "DELETE", "description": "Delete generated document"},
    {"path": "/candidates/{candidateId}/image/{key}", "method": "POST", "description": "Upload an image for an image-typed variable"},
    {"path": "/candidates/{candidateId}/image/{key}", "method": "GET", "description": "Stream the stored image for a variable (thumbnail + preview)"},
    {"path": "/candidates/{candidateId}/image/{key}", "method": "DELETE", "description": "Remove the stored image for a variable"}
  ],
  "migrations": [
    "001_setup.sql"
  ],
  "config": {
    "group": "P_synaform",
    "settings": [
      {"key": "enabled", "type": "boolean", "default": true, "description": "Enable Synaform plugin"},
      {"key": "default_language", "type": "string", "default": "de", "description": "Default language for forms and UI"},
      {"key": "company_name", "type": "string", "default": "", "description": "HR company name for document branding"},
      {"key": "extraction_model", "type": "string", "default": "default", "description": "Preferred AI model for CV extraction"},
      {"key": "validation_model", "type": "string", "default": "default", "description": "AI model for extraction validation (LLM-as-judge)"},
      {"key": "default_template_id", "type": "string", "default": "", "description": "Default DOCX template for generation"}
    ]
  }
}
