{
	# Global options
	#
	# FrankenPHP bootstrap. The synaplan-base-php image's
	# /usr/local/bin/synaplan-php-configure shim materializes
	# /etc/caddy/synaplan-worker-mode.Caddyfile on container startup:
	#   - APP_ENV=prod (and FRANKENPHP_WORKER_ENABLED!=0) -> the worker block
	#     (`frankenphp { worker { ... } }`, boots backend/public/worker.php
	#     once per worker process for ~3-10x throughput on Symfony)
	#   - APP_ENV=dev (or worker mode disabled)           -> a classic-SAPI
	#     stub containing only the bare `frankenphp` directive
	# Either flavor enables PHP processing, so this `import` always works.
	import /etc/caddy/synaplan-worker-mode.Caddyfile

	order php_server before file_server
}

:80 {
	# Enable compression — but NOT for the AI token streaming endpoints.
	# Caddy's encode directive buffers output for gzip/zstd, which would
	# defeat real-time delivery for chat token streams. The legacy widget
	# SSE/poll routes were removed in the realtime/Centrifugo migration,
	# so only the AI streaming endpoints stay on this exclusion list.
	@not_streaming {
		not path /api/v1/messages/stream /api/v1/widget/*/message
	}
	encode @not_streaming zstd gzip

	# Security headers (applied to all responses)
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Service Worker must never be cached by browsers or proxies
	@sw_files {
		path /sw.js
	}
	header @sw_files {
		Cache-Control "no-cache, no-store, must-revalidate"
		Service-Worker-Allowed "/"
	}

	# Web App Manifest should always be revalidated
	@manifest_file {
		path /site.webmanifest
	}
	header @manifest_file {
		Cache-Control "no-cache"
		Content-Type "application/manifest+json"
	}

	# Cache static assets from frontend
	@static_assets {
		path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp
		not path /widget.js /sw.js
	}
	header @static_assets {
		Cache-Control "public, max-age=31536000, immutable"
	}

	# Widget chunks can be cached aggressively (they have hashes in filenames)
	@widget_chunks {
		path /chunks/*
	}
	header @widget_chunks {
		Cache-Control "public, max-age=31536000, immutable"
	}

	# Widget entry point should not be cached at all
	@widget_entry {
		path /widget.js
	}
	header @widget_entry {
		Cache-Control "no-cache, no-store, must-revalidate"
		Pragma "no-cache"
		Expires "0"
	}

	# ------------------------------------------------------------------
	# Block scanners probing for dotfiles (.env, .git, ...) before they
	# reach PHP. Bots hammer the raw node IP for leaked secrets (e.g.
	# GET /api/.env); without this they fall through to @backend_php and
	# Symfony logs a NotFoundHttpException at ERROR level on every hit.
	# Returning a clean 404 at the edge keeps the request log readable and
	# avoids waking the PHP worker for obviously hostile traffic.
	# Placed before all other handles so it always wins.
	# ------------------------------------------------------------------
	@dotfiles {
		path */.env */.env.* */.git */.git/* /.env /.env.* /.git /.git/*
	}
	handle @dotfiles {
		respond 404
	}

	# ------------------------------------------------------------------
	# Realtime / WebSockets — proxied to the local Centrifugo instance.
	#
	# Browsers connect to /connection/websocket on the same origin so we
	# don't need CORS gymnastics or a separate subdomain. Centrifugo is
	# horizontally scaled across all 3 backend nodes via shared Redis,
	# so any node can accept the upgrade and still see publishes from
	# the other nodes.
	#
	# ONLY the client WebSocket endpoint is exposed. The Centrifugo admin
	# UI, HTTP server API and Prometheus endpoints are deliberately NOT
	# proxied: the PHP backend publishes container-to-container via
	# REALTIME_API_URL (http://centrifugo:8000/api), and operators reach
	# the admin UI through the internal network only (e.g. an SSH tunnel
	# or a docker port mapping bound to localhost) — see docs/REALTIME.md.
	# ------------------------------------------------------------------
	handle /connection/* {
		reverse_proxy centrifugo:8000
	}

	# Widgets first (to catch widget.js, chunks/*, etc.)
	@widget_file {
		file {
			root /var/www/widgets
			try_files {path}
		}
	}
	handle @widget_file {
		# CORS for widget files
		header Access-Control-Allow-Origin "*"
		root * /var/www/widgets
		file_server
	}

	# Missing widget assets must NOT fall through to the SPA fallback, which
	# would serve index.html as HTTP 200 without CORS and break cross-origin
	# <script type="module"> loads (the post-deploy stale-widget.js failure
	# mode). Return a clean 404 that still carries CORS, and never cache it.
	@widget_missing {
		path /widget.js /chunks/*
	}
	handle @widget_missing {
		header Access-Control-Allow-Origin "*"
		header Cache-Control "no-store"
		respond 404
	}

	# Frontend files second (static files from frontend build)
	@frontend_file {
		file {
			root /var/www/frontend
			try_files {path}
		}
	}
	handle @frontend_file {
		root * /var/www/frontend
		file_server
	}

	# Backend static files third (bundles, uploads)
	@backend_file {
		path /bundles/* /uploads/*
		file {
			root /var/www/backend/public
			try_files {path}
		}
	}
	handle @backend_file {
		root * /var/www/backend/public
		file_server
	}

	# Backend PHP routes last (API, dynamic routes, shared pages)
	# Dev routes (_profiler, _wdt, _error) only when APP_ENV=dev
	# /shared/* routes to PHP for Open Graph meta tags (social media previews)
	@backend_php expression `
		path('/up/*') ||
		path('/api/*') ||
		path('/api.php') ||
		path('/widget.php') ||
		path('/shared/*') ||
		path('/v1/*') ||
		path('/mcp') ||
		path('/.well-known/oauth-protected-resource') ||
		path('/.well-known/oauth-protected-resource/*') ||
		({env.APP_ENV} == 'dev' && (path('/_profiler/*') || path('/_wdt/*') || path('/_error/*')))
	`
	handle @backend_php {
		root * /var/www/backend/public
		php_server
	}

	# Fallback to frontend SPA (index.html)
	#
	# The HTML shell must always be revalidated: it references content-hashed
	# JS/CSS bundles, so a stale shell would point at bundles that no longer
	# exist after a deploy (the classic stale-SPA / 404-chunk failure). This
	# header previously lived in the Cloudflare edge Worker; keeping it at the
	# origin lets us run with CF as a transparent proxy (no Worker required).
	handle {
		header Cache-Control "no-cache"
		root * /var/www/frontend
		rewrite * /index.html
		file_server
	}
}
