FROM ollama/ollama:latest

# Install curl for healthcheck
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Comma- or space-separated list of models to pre-pull (override via compose env)
ENV OLLAMA_PULL_MODELS="llama3.2:3b mistral:7b codellama:7b"

# Start Ollama, wait for ready, pull requested models, then restart in foreground
ENTRYPOINT ["sh", "-lc", "set -e; ollama serve & until curl -sf localhost:11434/api/tags; do sleep 2; done; list=$(echo $OLLAMA_PULL_MODELS | tr ',' ' '); for m in $list; do echo Pulling $m; ollama pull $m || true; done; echo 'All models ready!'; pkill ollama || true; sleep 2; exec ollama serve"]