{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": ["before 7am on monday"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 6,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Automerge linters, formatters, static analysis, and type definitions",
      "matchPackageNames": [
        "eslint",
        "eslint-*",
        "@eslint/*",
        "@typescript-eslint/*",
        "eslint-plugin-vue",
        "eslint-config-prettier",
        "@vue/eslint-config-*",
        "prettier",
        "friendsofphp/php-cs-fixer",
        "phpstan/*",
        "@types/*"
      ],
      "matchUpdateTypes": ["patch", "minor", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Group Symfony runtime updates",
      "matchPackageNames": ["symfony/*"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "symfony"
    },
    {
      "description": "Group Doctrine runtime updates",
      "matchPackageNames": ["doctrine/*"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "doctrine"
    },
    {
      "description": "Group API Platform runtime updates",
      "matchPackageNames": ["api-platform/*"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "api-platform"
    },
    {
      "description": "Group Vue ecosystem updates",
      "matchPackageNames": ["vue", "vue-router", "pinia", "@vue/*", "vue-tsc"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "vue ecosystem"
    },
    {
      "description": "Group npm runtime dependencies",
      "matchPackageNames": ["marked", "katex", "dompurify", "@vueuse/*", "chart.js", "highlight.js"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm runtime"
    },
    {
      "description": "Group Composer runtime dependencies (non-framework)",
      "matchPackageNames": [
        "google/*",
        "grpc/*",
        "nelmio/*",
        "stripe/*",
        "smalot/*",
        "openai-php/*",
        "web-token/*",
        "phpoffice/*",
        "webklex/*",
        "netflie/*"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "composer runtime"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github actions"
    }
  ]
}
