{
    "type": "project",
    "license": "Apache-2.0",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/doctrine-orm": "^4.3.5",
        "api-platform/symfony": "^4.3.5",
        "ardagnsrn/ollama-php": "^1.0.5",
        "codewithkyrian/whisper.php": "^1.1",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.5",
        "erusev/parsedown": "^1.8.0",
        "firebase/php-jwt": "^7.0.5",
        "gemini-api-php/client": "^1.7.2",
        "google/apiclient": "^2.19.2",
        "google/protobuf": "^5.34.1",
        "google/recaptcha": "^1.5.0",
        "grpc/grpc": "^1.80",
        "hoels/app-store-server-library-php": "^2.0",
        "jumbojett/openid-connect-php": "^1.0.2",
        "league/flysystem-aws-s3-v3": "^3.32.0",
        "lucianotonet/groq-php": "^1.3",
        "mcp/sdk": "^0.6.0",
        "nelmio/api-doc-bundle": ">=5.10.0",
        "nelmio/cors-bundle": "^2.6.1",
        "netflie/whatsapp-cloud-api": "^4.0.0",
        "openai-php/client": "^0.20.0",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpoffice/phppresentation": "dev-master as 1.3.0",
        "phpoffice/phpspreadsheet": "^5.8.0",
        "phpoffice/phpword": "^1.4",
        "phpstan/phpdoc-parser": "^2.3.2",
        "predis/predis": "^3.0.0",
        "smalot/pdfparser": "^2.12.5",
        "stripe/stripe-php": "^20.1",
        "symfony/asset": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/doctrine-messenger": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/expression-language": "8.1.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/lock": "8.1.*",
        "symfony/mailer": "8.1.*",
        "symfony/messenger": "8.1.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/process": "8.1.*",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/rate-limiter": "8.1.*",
        "symfony/redis-messenger": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/serializer": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/validator": "8.1.*",
        "symfony/yaml": "8.1.*",
        "web-token/jwt-library": "^4.1.6",
        "webklex/php-imap": "^6.2"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "codewithkyrian/platform-package-installer": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Inference\\": "lib/grpc/Inference/",
            "GPBMetadata\\": "lib/grpc/GPBMetadata/"
        },
        "files": [
            "config/plugin-autoloader.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@proto:generate",
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@proto:generate",
            "@auto-scripts"
        ],
        "lint": "php-cs-fixer check --diff",
        "lint:fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "proto:generate": [
            "protoc --php_out=lib/grpc --proto_path=proto/triton proto/triton/grpc_service.proto proto/triton/model_config.proto"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "dg/bypass-finals": "^1.9",
        "friendsofphp/php-cs-fixer": "^3.95.1",
        "phpstan/phpstan": "^2.1.53",
        "phpstan/phpstan-doctrine": "^2.0.21",
        "phpunit/phpunit": "^12.5.23",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/maker-bundle": "^1.67.0"
    }
}
