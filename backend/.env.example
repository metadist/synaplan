# ==============================================================================
# SYNAPLAN ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy to .env (git-ignored) and adjust values as needed.
# Sections match the Admin → System Config UI tabs.
# ==============================================================================


# ==============================================================================
# 1. APPLICATION CORE
# ==============================================================================
# Essential application settings and URLs
# ==============================================================================

# APP_ENV is set via docker-compose environment, not here
APP_SECRET=changeme_in_production

# Log format: json (production) or text (development)
LOG_FORMAT=text

# Secret key for HMAC-signing access tokens (change in production!)
TOKEN_SECRET=changeme_use_strong_secret_in_production

# --- Shared infrastructure (Redis + Realtime gateway) ---
# Redis is the canonical cross-node platform service. It backs:
#   * Symfony cache (framework.cache.app and per-feature pools)
#   * Symfony lock (LOCK_DSN below)
#   * Symfony rate-limiter (per-user quotas)
#   * Centrifugo realtime engine (separate logical DB)
# Production: point all 3 backend nodes at the same managed Redis.
REDIS_DSN=redis://redis:6379

# Lock component for background processes (prevents overlapping cron jobs)
# Defaults to Redis so locks are visible across web nodes.
# Options: redis://host:port (recommended), flock (single-node only), semaphore
LOCK_DSN=redis://redis:6379

# --- Realtime gateway (Centrifugo WebSockets) ---
# Master kill-switch for browser realtime. When false the backend stops
# publishing to Centrifugo AND the frontend stops opening WS connections
# — there is no fallback transport, the dashboard simply degrades to its
# REST endpoints (no live updates) until this is re-enabled.
REALTIME_ENABLED=true
# Internal Centrifugo HTTP API (server-to-server publish).
REALTIME_API_URL=http://centrifugo:8000/api
# HMAC secret used by RealtimeTokenService (PHP) to sign JWTs that the
# browser presents to Centrifugo on connect. MUST match the centrifugo.json
# `token_hmac_secret_key`. Generate with: openssl rand -hex 32
# PROD GUARD: with APP_ENV=prod the backend REFUSES to mint tokens while
# this still has the changeme_* placeholder (known secret = forgeable JWTs).
REALTIME_TOKEN_SECRET=changeme_centrifugo_token_secret
# Pre-shared API key for backend-to-Centrifugo HTTP publish calls.
# PROD GUARD: with APP_ENV=prod publishes are skipped (and an error logged)
# while this still has the changeme_* placeholder.
REALTIME_API_KEY=changeme_centrifugo_api_key
# Public WebSocket URL the browser dials. Empty string = same-origin
# (Caddy reverse-proxies /connection/* to centrifugo). Override for
# cross-origin widget embeds.
REALTIME_PUBLIC_WS_URL=
# Comma-separated origins allowed to upgrade to WS (Centrifugo-side).
# Use "*" only in dev. Production: https://yourdomain.com,https://app.yourdomain.com
REALTIME_ALLOWED_ORIGINS=*
# Redis address for the Centrifugo engine (cross-node WebSocket pub/sub).
# Defaults to the local Redis on a dedicated logical DB (/3) so Centrifugo keys
# stay isolated from Symfony cache/lock/messenger (which use REDIS_DSN on /0).
# Production: point at the same shared/managed Redis as REDIS_DSN, keeping the
# /3 suffix — e.g. redis://redis-prod.internal:6379/3.
# (For Redis Cluster, drop the DB suffix: redis://redis-prod.internal:6379)
REALTIME_REDIS_ADDRESS=redis://redis:6379/3
# Centrifugo admin UI (optional, expose only on private network).
REALTIME_ADMIN_PASSWORD=changeme_admin
REALTIME_ADMIN_SECRET=changeme_admin_secret

# Public URLs
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:8000

# Misc
AUTO_DOWNLOAD_MODELS=false


# ==============================================================================
# 2. AI SERVICES
# ==============================================================================
# Configure AI providers for chat, embeddings, and content generation
# ==============================================================================

# --- Local AI (Ollama) ---
# Docker: http://ollama:11434 | Local: http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434

# --- Cloud AI Providers (optional - Ollama works without these) ---
OPENAI_API_KEY=
OPENAI_STORE_RESPONSES=false
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
# Mistral AI: chat (Mistral Medium/Large) + Voxtral audio (transcription & TTS)
# Get API key: https://console.mistral.ai/
MISTRAL_API_KEY=

# --- TheHive AI (Image Generation) ---
# Get API key: https://thehive.ai/
# Models: Flux Schnell, Flux Schnell Enhanced, SDXL, SDXL Enhanced, Emoji
THEHIVE_API_KEY=

# --- Higgsfield AI (Image + Video Generation) ---
# Get a key+secret pair: https://cloud.higgsfield.ai/ → Settings → API
# Models on the key-auth tier include Soul Standard (text→image), DoP Standard,
# Kling 2.1 Pro, ByteDance Seedance v1 Pro, Seedream v4 (text→image / image→video).
# Authentication is "Authorization: Key {api_key}:{api_secret}" — both halves
# are required. Generation is asynchronous: submit → poll → fetch URL.
# Leave EITHER variable empty to disable the platform-wide credential; users
# can still configure a per-user key in their Synaplan settings, which is
# stored encrypted at rest (AES-256-CBC via APP_SECRET).
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# --- Cloudflare Workers AI (Embeddings) ---
# Fast, low-cost bge-m3 embeddings via Cloudflare's edge network.
# Use as primary provider for local dev, or as auto-fallback in production.
# Get credentials: https://dash.cloudflare.com → Workers & Pages → Overview
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Embedding fallback: provider name to try when the primary embedding fails.
# Set to "cloudflare" to auto-failover to Cloudflare Workers AI.
# Leave empty to disable fallback.
EMBEDDING_FALLBACK_PROVIDER=

# --- Self-Hosted AI (optional) ---
# NVIDIA Triton gRPC endpoint (port 8001 default)
# Example: triton-server:8001 (Docker) or localhost:8001 (local)
TRITON_SERVER_URL=

# --- Text-to-Speech (optional) ---
# Piper TTS (self-hosted, free, multi-language)
# Run via synaplan-tts repo: docker compose up -d (binds to port 10200)
# Docker Compose sets http://host.docker.internal:10200 (via extra_hosts on Linux)
# Native/local: fallback is http://localhost:10200
SYNAPLAN_TTS_URL=

# ElevenLabs (cloud TTS)
ELEVENLABS_API_KEY=


# ==============================================================================
# 3. EMAIL CONFIGURATION
# ==============================================================================
# Outbound email for notifications, password resets, and signups
# ==============================================================================

# SMTP connection string
# Dev: null://null (no emails) or smtp://mailhog:1025 (test UI at localhost:8025)
# Prod: smtp://user:pass@smtp.example.com:587
# AWS SES (or any server that drops idle connections quickly): append
# ?ping_threshold=9 — SES hard-closes connections idle >~10s while Symfony
# only pings after 100s, so reused connections in long-running workers fail
# with "451 4.4.2 Timeout waiting for data from client" otherwise.
MAILER_DSN=null://null

# Sender information (optional - uses system defaults if empty)
APP_SENDER_EMAIL=
APP_SENDER_NAME=Synaplan


# ==============================================================================
# 4. AUTHENTICATION & SECURITY
# ==============================================================================
# OAuth providers, SSO, and security features
# ==============================================================================

# --- Google reCAPTCHA v3 ---
# Get keys: https://www.google.com/recaptcha/admin
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here
RECAPTCHA_MIN_SCORE=0.5

# --- Google OAuth 2.0 ---
# Get credentials: https://console.cloud.google.com/apis/credentials
# Callback URL: {APP_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT_ID=
# Optional: OAuth2 access token for Vertex AI Imagen (enterprise). Imagen 4 uses the Gemini API key above by default.
# Do not confuse with GOOGLE_GEMINI_API_KEY — Vertex expects a short-lived bearer from gcloud or a service account.
GOOGLE_VERTEX_ACCESS_TOKEN=

# --- GitHub OAuth 2.0 ---
# Get credentials: https://github.com/settings/developers
# Callback URL: {APP_URL}/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Sign in with Apple ---
# Required on iOS when other third-party sign-ins are offered (App Store
# Guideline 4.8). Configure under developer.apple.com → Certificates,
# Identifiers & Profiles.
# Web callback URL (add as a Return URL on the Services ID):
#   {APP_URL}/api/v1/auth/apple/callback
# Services ID = web/Android OAuth client_id AND the web id_token audience.
APPLE_CLIENT_ID=
# Apple Developer Team ID (10 chars), e.g. X9GM4T2MQG
APPLE_TEAM_ID=
# Key ID of the Sign-in-with-Apple private key (.p8), e.g. S6YQ877G37
APPLE_KEY_ID=
# Contents of AuthKey_XXXX.p8 (PKCS#8 PEM). Keep the BEGIN/END lines; a single
# line with literal \n newlines is accepted.
APPLE_PRIVATE_KEY=
# Native iOS bundle id = audience of the identity token from the native sign-in.
# Defaults to com.synaplan.app; only change for a custom bundle id.
APPLE_APP_BUNDLE_ID=com.synaplan.app

# --- OIDC (Enterprise SSO) ---
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTO_REDIRECT=false
# Space-separated OIDC scopes requested during login.
# Remove offline_access if your provider doesn't support it (internal app tokens provide a 7-day fallback).
OIDC_SCOPES="openid email profile offline_access"
# Comma-separated OIDC claim values that grant admin (matched case-insensitively)
OIDC_ADMIN_ROLES=admin,realm-admin,synaplan-admin,administrator
# Comma-separated dot-notation paths to extract roles from OIDC tokens.
# Use {client_id} as placeholder for OIDC_CLIENT_ID. Escape literal dots with \
# Default (Keycloak): realm_access.roles,resource_access.{client_id}.roles,groups
# Azure AD: roles
# Auth0: https://myapp\.com/roles
OIDC_ROLE_CLAIMS=realm_access.roles,resource_access.{client_id}.roles,groups
# Expected JWT audience for OIDC bearer token auth (e.g. from synaplan-opencloud token exchange).
# Defaults to OIDC_CLIENT_ID if not set.
# OIDC_BEARER_AUDIENCE=

# --- MCP (Model Context Protocol) server ---
# Synaplan exposes a Streamable HTTP MCP endpoint at POST /mcp (authenticated by
# API key or OIDC bearer). MCP_ALLOWED_HOSTS is a comma-separated list of extra
# hostnames (no port) accepted by the endpoint's DNS-rebinding protection, on top
# of localhost variants and the APP_URL host. Set it to your public MCP host(s)
# in production, e.g. "web.synaplan.com".
MCP_ALLOWED_HOSTS=


# ==============================================================================
# 5. INBOUND CHANNELS
# ==============================================================================
# External channels for interacting with the AI platform
# ==============================================================================

# --- WhatsApp Business API ---
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Optional: override Graph API base URL (e.g. http://127.0.0.1:3999 for CI stub). Empty = use graph.facebook.com
WHATSAPP_GRAPH_API_BASE_URL=

# --- Smart Mail (Gmail IMAP) ---
# For AI-powered email responses via smart@yourdomain.com
# Requires: 2-Step Verification enabled on Google account
# Generate App Password: https://myaccount.google.com/apppasswords
# See: backend/docs/GMAIL_APP_PASSWORD_SETUP.md
GMAIL_USERNAME=
GMAIL_PASSWORD=


# ==============================================================================
# 6. DOCUMENT PROCESSING
# ==============================================================================
# Text extraction, OCR, transcription, and web search
# ==============================================================================

# --- Apache Tika (Text Extraction) ---
TIKA_BASE_URL=http://tika:9998
TIKA_TIMEOUT_MS=30000
TIKA_RETRIES=2
TIKA_RETRY_BACKOFF_MS=1000
TIKA_HTTP_USER=
TIKA_HTTP_PASS=
TIKA_MIN_LENGTH=10
TIKA_MIN_ENTROPY=3.0

# --- PDF Rasterizer (OCR for scanned PDFs) ---
RASTERIZE_DPI=150
RASTERIZE_PAGE_CAP=10
RASTERIZE_TIMEOUT_MS=30000

# --- Whisper (Audio Transcription) ---
WHISPER_ENABLED=true
WHISPER_DEFAULT_MODEL=base
WHISPER_BINARY=/usr/local/bin/whisper
WHISPER_MODELS_PATH=/var/www/backend/var/whisper
FFMPEG_BINARY=/usr/bin/ffmpeg

# --- Brave Web Search ---
# Get API key: https://api.search.brave.com/
#
# Default is `true` because the project-wide routing policy
# (`WebSearchTopicPolicy`) treats internet search as the default for every
# chat. Without a configured `BRAVE_SEARCH_API_KEY`, `BraveSearchService::isEnabled()`
# still returns false, so leaving the key empty is the right way to
# opt out — no need to also flip `BRAVE_SEARCH_ENABLED=false`. Set it
# to `false` only if you have an API key but want to forcibly suppress
# all search calls anyway (testing/cost-cap scenarios).
BRAVE_SEARCH_ENABLED=true
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_API_URL=https://api.search.brave.com/res/v1
BRAVE_SEARCH_COUNT=10
BRAVE_SEARCH_COUNTRY=us
BRAVE_SEARCH_SEARCH_LANG=en


# ==============================================================================
# 7. VECTOR DATABASE
# ==============================================================================
# Qdrant for semantic search, user memories, and RAG document vectors
# ==============================================================================

# Qdrant Vector Database (internal Docker service, no config needed)
QDRANT_URL=http://qdrant:6333

# ==============================================================================
# 8. PAYMENTS & BILLING (manual edit only)
# ==============================================================================
# Stripe integration - not editable via web UI for security
# ==============================================================================

# ------------------------------------------------------------------------------
# Cost-budget gate (issue #886)
# ------------------------------------------------------------------------------
# When true, /messages/send and /messages/stream block once the user has burned
# through BCOST_BUDGET_MONTHLY for the current period. The check runs BEFORE the
# request, so the in-flight answer always finishes; the NEXT message is blocked.
#
# This is the primary spend-bound for authenticated users: the AI output is no
# longer clamped per plan (every authenticated tier gets the model's full
# max_tokens), so the cost budget — not an output cap — limits spend. Tiers
# without a budget (budget = 0) stay unlimited and fall back to message-count
# limits (e.g. ANONYMOUS). Self-hosted/Open-Source installs without budgets are
# unaffected.
COST_BUDGET_GATE_ENABLED=true

# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs from Stripe Dashboard (Products → Prices)
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_TEAM=price_team_monthly
STRIPE_PRICE_BUSINESS=price_business_monthly

# ── Native in-app purchase (IAP) products — mobile app only (Epic 5.5) ──────
# Store product IDs that map an Apple/Google IAP back to a Synaplan tier
# (the IAP mirror of STRIPE_PRICE_* above). Create the products in App Store
# Connect / Play Console, then set the IDs here. Defaults are the documented
# placeholder convention, so web-only / open-source deployments keep IAP off
# (IapPricingService::isConfigured() stays false).
#
# IMPORTANT: the STORE price for each tier BAKES IN the store commission
# (≈30 %, sometimes 15 %). See docs/PAYMENTS_CHANNELS.md before setting prices.
IAP_PRODUCT_PRO=com.synaplan.app.pro.monthly
IAP_PRODUCT_TEAM=com.synaplan.app.team.monthly
IAP_PRODUCT_BUSINESS=com.synaplan.app.business.monthly

# Store commission passed on to app buyers, in percent ON TOP of the web price.
# The /subscription/plans endpoint exposes `appPrice = price * (1 + markup/100)`,
# snapped to the nearest x.99 store price point (e.g. 19.95 + 30 % → 25.99).
# The native app shows it as its fallback price (the store's own localized
# price wins once loaded); the web always shows the plain `price`. Set the
# App Store Connect / Play Console product prices to match this value.
IAP_PRICE_MARKUP_PERCENT=30

# ── IAP server-side receipt validation — mobile app only (Epic 5.4) ─────────
# Credentials for verifying purchases server-side (the server is the single
# source of truth — never trust a client success callback). All optional:
# leave unset and IAP validation stays disabled (verifiers report not-configured
# → /api/v1/iap/* returns 503). These are account-bound; see
# synaplan-apps/docs/LAUNCH_CHECKLIST.md + docs/SECRETS.md.
#
# Apple (App Store Server Library / StoreKit 2 JWS verification):
#   IAP_APPLE_BUNDLE_ID         your app bundle id, e.g. com.synaplan.app
#   IAP_APPLE_APP_APPLE_ID      numeric App Store app id (required in production)
#   IAP_APPLE_ENVIRONMENT       Sandbox | Production (default Production)
#   IAP_APPLE_ROOT_CERTS_DIR    dir containing Apple root CA cert files (.cer/.pem)
IAP_APPLE_BUNDLE_ID=
IAP_APPLE_APP_APPLE_ID=
IAP_APPLE_ENVIRONMENT=Production
IAP_APPLE_ROOT_CERTS_DIR=
# Google (Play Developer API via service account):
#   IAP_GOOGLE_PACKAGE_NAME            Android package, e.g. com.synaplan.app
#   IAP_GOOGLE_SERVICE_ACCOUNT_JSON    absolute path to the service-account JSON
IAP_GOOGLE_PACKAGE_NAME=
IAP_GOOGLE_SERVICE_ACCOUNT_JSON=

# Payment methods (comma-separated)
# Available: card, link, sepa_debit, klarna, bancontact, eps, giropay, ideal, p24, sofort
# Note: Apple Pay and Google Pay are offered automatically alongside `card` on
# hosted Stripe Checkout — no separate payment_method_type, no domain
# verification needed (Stripe owns checkout.stripe.com). `sepa_debit` (IBAN)
# is shown in EUR for EU customers; the first SEPA payment confirms in 1–14
# working days, after which the subscription transitions to `active`.
STRIPE_PAYMENT_METHODS=card,link,sepa_debit,klarna

# Stripe Tax integration (https://stripe.com/tax).
# When true, Checkout calculates VAT/GST automatically from the collected
# billing address, applies EU B2B reverse-charge when a valid VAT ID is given,
# and generates tax-compliant invoice PDFs. Requires:
#   1. Activating Stripe Tax in Dashboard → Settings → Tax
#   2. A tax code assigned to each Product
# Leave disabled if you issue invoices yourself — the checkout will still
# collect name + billing address + tax ID (always on, free), so you have the
# data needed for a manual tax-compliant invoice.
STRIPE_AUTOMATIC_TAX=false

# Pre-made Stripe Payment Links (https://dashboard.stripe.com/payment-links):
# For tax-compliant collection on those links, edit each link and enable:
#   - "Collect customers' addresses" → Billing address: Required
#   - "Allow customers to enter tax IDs"
#   - "Collect tax automatically" (only if Stripe Tax is activated)
# These are dashboard settings, not env vars.


# ==============================================================================
# 9. DATABASE (manual edit only)
# ==============================================================================
# MySQL/MariaDB connection - not editable via web UI for security
# ==============================================================================

# Docker Compose credentials
MYSQL_DATABASE=synaplan
MYSQL_USER=synaplan_user
MYSQL_PASSWORD=synaplan_password
MYSQL_ROOT_PASSWORD=root_password

# Doctrine URLs (read/write replica pattern)
# Format: mysql://user:password@host:port/database?serverVersion=X.X&charset=utf8mb4
DATABASE_WRITE_URL=mysql://synaplan_user:synaplan_password@db:3306/synaplan?serverVersion=mariadb-12.2.2&charset=utf8mb4
DATABASE_READ_URL=mysql://synaplan_user:synaplan_password@db:3306/synaplan?serverVersion=mariadb-12.2.2&charset=utf8mb4

# =============================================================================
# --- Discord Webhook (optional) ---
# Send notifications to Discord when WhatsApp messages are processed
# Get webhook URL from Discord: Server Settings > Integrations > Webhooks
# =============================================================================
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1234567890/abcdefghijklmnopqrstuvwxyz

# =============================================================================
# --- Guest Trial Chat (optional) ---
# Anti-abuse cap on concurrent active guest sessions per client IP.
# Defaults to 5 when unset. Raise only in test environments where many
# sessions legitimately share one IP.
# =============================================================================
GUEST_MAX_SESSIONS_PER_IP=5
